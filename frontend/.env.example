# ============================================================
# GAE Client 환경 변수 설정 파일
# ============================================================
# 사용법:
#   1. 이 파일을 복사하여 .env 파일 생성: cp .env.example .env
#   2. .env 파일의 값을 실제 값으로 수정
#   3. 개발 서버 실행: npm run dev
# ============================================================
# 주의: Vite에서는 반드시 VITE_ 접두사가 필요합니다!
# ============================================================

# ==================== API ====================
# 백엔드 API 주소
VITE_API_BASE_URL=http://localhost:8080/api
# WebSocket 주소
VITE_WS_URL=ws://localhost:8080/ws/websocket

# ==================== MQTT (Jetson Mosquitto) ====================
# 제슨 MQTT 브로커 IP (WiFi 변경 시 여기만 수정)
VITE_MQTT_BROKER_IP=<your-jetson-ip>

# ==================== Firebase ====================
# Firebase Console > 프로젝트 설정 > 일반 > 내 앱 > SDK 설정 및 구성
VITE_FIREBASE_API_KEY=<your-api-key>
VITE_FIREBASE_AUTH_DOMAIN=<your-project>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<your-project-id>
VITE_FIREBASE_STORAGE_BUCKET=<your-project>.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=<sender-id>
VITE_FIREBASE_APP_ID=<app-id>

# Firebase Cloud Messaging (FCM) VAPID 키
# Firebase Console > 프로젝트 설정 > 클라우드 메시징 > 웹 구성 > 키 쌍
VITE_FIREBASE_VAPID_KEY=<vapid-key-from-cloud-messaging>

# ==================== Kakao Map ====================
# Kakao Developers > 내 애플리케이션 > 앱 키 > JavaScript 키 (지도 렌더링용)
VITE_KAKAO_MAP_API_KEY=<your-kakao-javascript-key>
# REST API 키와 GMS API 키는 백엔드 프록시로 이전됨 (backend/.env 참고)

# ==================== App 정보 ====================
VITE_APP_NAME=GAE
VITE_APP_VERSION=1.0.0
