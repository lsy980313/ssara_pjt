# ============================================================
# GAE Server 환경 변수 설정 파일
# ============================================================
# 사용법:
#   1. 이 파일을 복사하여 .env 파일 생성: cp .env.example .env
#   2. .env 파일의 값을 실제 값으로 수정
#   3. 서버 실행: ./gradlew bootRun
# ============================================================

# ==================== Database ====================
# PostgreSQL 연결 정보
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dog_gaje_db
DB_USERNAME=postgres
DB_PASSWORD=<your_database_password>

# ==================== JWT ====================
# JWT 시크릿 키 (최소 256비트 권장)
# 생성 방법: openssl rand -base64 64
JWT_SECRET=<generate_with_openssl_rand_base64_64>
# 토큰 만료 시간 (밀리초) - 기본값: 24시간
JWT_EXPIRATION=86400000

# ==================== Server ====================
SERVER_PORT=8080
# 프로파일: dev, prod
SPRING_PROFILES_ACTIVE=dev

# ==================== Firebase (FCM 푸시 알림) ====================
# Firebase Console > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성
# 다운로드한 JSON 파일에서 각 값을 복사
FIREBASE_PROJECT_ID=<your-firebase-project-id>
FIREBASE_PRIVATE_KEY_ID=<from-service-account-json>
# 주의: 줄바꿈은 \n으로 표시, 전체를 따옴표로 감싸기
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<your-private-key>\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=<firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com>
FIREBASE_CLIENT_ID=<client-id-from-json>

# ==================== External API Keys (Proxy) ====================
GMS_API_KEY=<your-gms-api-key>
KAKAO_REST_API_KEY=<your-kakao-rest-api-key>

# ==================== ROS2 / rosbridge ====================
# rosbridge_server 연결 정보
ROSBRIDGE_HOST=localhost
ROSBRIDGE_PORT=9090

# ==================== CORS ====================
# 허용할 Origin (쉼표로 구분)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== 로깅 (선택) ====================
# 로그 레벨: TRACE, DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
