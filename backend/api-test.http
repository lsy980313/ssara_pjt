HTTP

### 1. 회원가입
# 이미 가입했다면 에러가 날 수 있습니다.
POST http://localhost:8080/api/auth/signup
Content-Type: application/json

{
  "email": "ssafy@gmail.com",
  "password": "1234",
  "name": "김싸피",
  "phoneNumber": "010-1234-5678"
}

### 2. 로그인 (토큰 발급)
# 여기서 나오는 "accessToken" 값을 복사
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "email": "ssafy@gmail.com",
  "password": "1234"
}

### 3. 내 정보 조회 (토큰 필요!)
# [사용법]
# 1. 위에서 로그인을 실행합니다.
# 2. 결과창의 "accessToken": "ey..." 부분에서 긴 토큰 값을 복사합니다.
# 3. 아래 'Bearer ' 뒤에 붙여넣기 하세요. (Bearer와 토큰 사이에 띄어쓰기 필수!)
GET http://localhost:8080/api/members/me
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiJzc2FmeUBnbWFpbC5jb20iLCJhdXRoIjoiUk9MRV9VU0VSLEZBQ1RPUl9QQVNTV09SRCIsImlhdCI6MTc2OTA2MzkyNiwiZXhwIjoxNzY5MTUwMzI2fQ.6TiYSm2-beGRn4hbwRACMOqxEFQGl4Wyy-C2pFKaOERxQRUH6qBWa9b7F-H3CrLA

### 4. 회원 정보 수정 (이름, 폰번호, 비밀번호 변경)
PATCH http://localhost:8080/api/members/me
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiJzc2FmeUBnbWFpbC5jb20iLCJhdXRoIjoiUk9MRV9VU0VSLEZBQ1RPUl9QQVNTV09SRCIsImlhdCI6MTc2OTA2MzkyNiwiZXhwIjoxNzY5MTUwMzI2fQ.6TiYSm2-beGRn4hbwRACMOqxEFQGl4Wyy-C2pFKaOERxQRUH6qBWa9b7F-H3CrLA
Content-Type: application/json

{
  "name": "슈퍼김싸피",
  "phoneNumber": "010-9999-8888",
  "password": "5678"
}

### 5. 수정 확인 (내 정보 조회 다시 해보기)
GET http://localhost:8080/api/members/me
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiJzc2FmeUBnbWFpbC5jb20iLCJhdXRoIjoiUk9MRV9VU0VSLEZBQ1RPUl9QQVNTV09SRCIsImlhdCI6MTc2OTA2MzkyNiwiZXhwIjoxNzY5MTUwMzI2fQ.6TiYSm2-beGRn4hbwRACMOqxEFQGl4Wyy-C2pFKaOERxQRUH6qBWa9b7F-H3CrLA

### 6. 회원 탈퇴
DELETE http://localhost:8080/api/members/me
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiJzc2FmeUBnbWFpbC5jb20iLCJhdXRoIjoiUk9MRV9VU0VSLEZBQ1RPUl9QQVNTV09SRCIsImlhdCI6MTc2OTA2MzkyNiwiZXhwIjoxNzY5MTUwMzI2fQ.6TiYSm2-beGRn4hbwRACMOqxEFQGl4Wyy-C2pFKaOERxQRUH6qBWa9b7F-H3CrLA