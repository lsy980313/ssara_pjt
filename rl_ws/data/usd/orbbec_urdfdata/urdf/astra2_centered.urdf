    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="../meshes/astra2/camera_depth_frame.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="camera_depth_joint" type="fixed">
    <!-- Shifted by +OFFSET to compensate for camera_link moving by -OFFSET -->
    <origin xyz="0.012323996 0.037500000 0.028150320" rpy="0 0 0" />
    <parent link="camera_link" />
    <child link="camera_depth_frame" />
    <axis xyz="0 0 0" />
  </joint>

  <link name="camera_depth_optical_frame">
    <inertial>
      <origin xyz="-5.33451517362171E-07 -6.08796009742075E-07 -0.00168460453866946" rpy="0 0 0" />
      <mass value="0.000608348661221202" />
      <inertia ixx="8.07147396496025E-09" ixy="1.28152628023353E-12" ixz="-8.05787556448886E-13" iyy="8.07148645937271E-09" iyz="-9.13275008052966E-13" izz="6.79778952271057E-09" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="../meshes/astra2/camera_depth_optical_frame.STL" />
