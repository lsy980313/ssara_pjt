<?xml version="1.0" encoding="utf-8"?>
<robot name="SpotMicroAI" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <material name="yellow">
    <color rgba="0.92 0.83 0.0 1"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>
  <material name="grey">
    <color rgba="0.6 0.6 0.6 1"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="../Parts/mainbody.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
      <origin rpy="0 0 0" xyz="-0.045 -0.060 -0.015"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.14 0.11 0.07"/>
      </geometry>
      <origin rpy="0 0 0" xyz="-0.045 -0.060 -0.015"/>
    </collision>
    <inertial>
      <mass value="2.00"/>
      <inertia ixx="0.00283" ixy="0" ixz="0" iyy="0.00408" iyz="0" izz="0.00528"/>
    </inertial>
  </link>

  <link name="rear_link">
